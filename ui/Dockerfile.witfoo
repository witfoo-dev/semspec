# WitFoo override: run SvelteKit with Node adapter (upstream uses Caddy which breaks SSR)
FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM node:20-alpine
RUN apk add --no-cache wget
WORKDIR /app
COPY --from=builder /app/build .
COPY --from=builder /app/package.json .
ENV PORT=3000
EXPOSE 3000
HEALTHCHECK --interval=5s --timeout=3s --retries=5 CMD wget -q --spider http://localhost:3000 || exit 1
CMD ["node", "index.js"]
