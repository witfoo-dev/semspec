# Production Caddy configuration
# Proxies API requests to semspec backend, all else to UI Node SSR server

:8080 {
    # API routes to semspec backend
    handle /agentic-dispatch/* {
        reverse_proxy semspec:8080
    }

    handle /workflow-api/* {
        reverse_proxy semspec:8080
    }

    handle /graphql {
        reverse_proxy semspec:8082
    }

    handle /health {
        reverse_proxy semspec:8080
    }

    handle /readyz {
        reverse_proxy semspec:8080
    }

    handle /metrics {
        reverse_proxy semspec:8080
    }

    # All other routes to UI Node SSR server
    handle {
        reverse_proxy ui:3000
    }
}
