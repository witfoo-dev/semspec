{
  "version": "1.0.2",
  "platform": {
    "org": "semspec",
    "id": "semspec-e2e-gemini",
    "environment": "test"
  },
  "nats": {
    "urls": [
      "nats://nats:4222"
    ],
    "max_reconnects": -1,
    "reconnect_wait": "2s",
    "jetstream": {
      "enabled": true
    }
  },
  "model_registry": {
    "endpoints": {
      "gemini-flash": {
        "provider": "openai",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-2.5-flash",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "stream": true,
        "reasoning_effort": "low"
      },
      "gemini-pro": {
        "provider": "openai",
        "url": "https://generativelanguage.googleapis.com/v1beta/openai",
        "model": "gemini-2.5-pro",
        "api_key_env": "GEMINI_API_KEY",
        "max_tokens": 1048576,
        "supports_tools": true,
        "stream": true,
        "reasoning_effort": "low"
      }
    },
    "capabilities": {
      "planning": {
        "description": "Plan generation and architecture",
        "preferred": [
          "gemini-pro"
        ],
        "fallback": [
          "gemini-flash"
        ]
      },
      "writing": {
        "description": "Documentation, plans, specifications",
        "preferred": [
          "gemini-flash"
        ]
      },
      "coding": {
        "description": "Code generation, implementation",
        "preferred": [
          "gemini-flash"
        ]
      },
      "reviewing": {
        "description": "Code review, quality analysis",
        "preferred": [
          "gemini-flash"
        ]
      },
      "task_generation": {
        "description": "Task decomposition",
        "preferred": [
          "gemini-flash"
        ]
      },
      "task_reviewing": {
        "description": "Task review",
        "preferred": [
          "gemini-flash"
        ]
      },
      "requirement_generation": {
        "description": "Requirement decomposition",
        "preferred": [
          "gemini-flash"
        ]
      },
      "scenario_generation": {
        "description": "BDD scenario generation",
        "preferred": [
          "gemini-flash"
        ]
      },
      "fast": {
        "description": "Quick responses, classification",
        "preferred": [
          "gemini-flash"
        ]
      }
    },
    "defaults": {
      "model": "gemini-flash"
    }
  },
  "services": {
    "service-manager": {
      "name": "service-manager",
      "enabled": true,
      "config": {
        "http_port": 8080
      }
    },
    "component-manager": {
      "name": "component-manager",
      "enabled": true,
      "config": {}
    },
    "heartbeat": {
      "name": "heartbeat",
      "enabled": false,
      "config": {}
    },
    "message-logger": {
      "name": "message-logger",
      "enabled": true,
      "config": {
        "buffer_size": 10000,
        "monitor_subjects": [
          "user.>",
          "agent.>",
          "tool.>",
          "graph.>",
          "workflow.>",
          "source.>",
          "context.>"
        ]
      }
    }
  },
  "components": {
    "agentic-dispatch": {
      "name": "agentic-dispatch",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_role": "general",
        "default_model": "gemini-flash",
        "auto_continue": false,
        "stream_name": "USER",
        "permissions": {
          "view": [
            "*"
          ],
          "submit_task": [
            "*"
          ],
          "cancel_own": true,
          "cancel_any": [
            "admin"
          ],
          "approve": [
            "*"
          ]
        }
      }
    },
    "agentic-loop": {
      "name": "agentic-loop",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_iterations": 40,
        "timeout": "900s",
        "stream_name": "AGENT",
        "loops_bucket": "AGENT_LOOPS",
        "content_bucket": "AGENT_CONTENT"
      }
    },
    "agentic-model": {
      "name": "agentic-model",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "timeout": "900s"
      }
    },
    "agentic-tools": {
      "name": "agentic-tools",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "consumer_name_suffix": "semspec-e2e"
      }
    },
    "rdf-export": {
      "name": "rdf-export",
      "type": "output",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entities_in",
              "subject": "graph.ingest.entity",
              "type": "jetstream",
              "stream_name": "GRAPH"
            }
          ],
          "outputs": [
            {
              "name": "rdf_out",
              "subject": "graph.export.rdf",
              "type": "nats"
            }
          ]
        },
        "format": "turtle",
        "profile": "minimal",
        "base_iri": "https://semspec.dev"
      }
    },
    "graph-ingest": {
      "name": "graph-ingest",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entities_in",
              "subject": "graph.ingest.entity",
              "type": "jetstream",
              "stream_name": "GRAPH"
            }
          ],
          "outputs": [
            {
              "name": "entity_states",
              "subject": "ENTITY_STATES",
              "type": "kv-write"
            }
          ]
        },
        "enable_hierarchy": true
      }
    },
    "graph-index": {
      "name": "graph-index",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entity_watch",
              "subject": "ENTITY_STATES",
              "type": "kv-watch"
            }
          ],
          "outputs": [
            {
              "name": "outgoing_index",
              "subject": "OUTGOING_INDEX",
              "type": "kv"
            },
            {
              "name": "incoming_index",
              "subject": "INCOMING_INDEX",
              "type": "kv"
            },
            {
              "name": "alias_index",
              "subject": "ALIAS_INDEX",
              "type": "kv"
            },
            {
              "name": "predicate_index",
              "subject": "PREDICATE_INDEX",
              "type": "kv"
            }
          ]
        },
        "workers": 2,
        "batch_size": 50,
        "coalesce_ms": 100
      }
    },
    "graph-embedding": {
      "name": "graph-embedding",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entity_watch",
              "subject": "ENTITY_STATES",
              "type": "kv-watch"
            }
          ],
          "outputs": [
            {
              "name": "embeddings",
              "subject": "EMBEDDINGS_CACHE",
              "type": "kv"
            }
          ]
        },
        "embedder_type": "bm25",
        "batch_size": 50,
        "cache_ttl": "1h",
        "coalesce_ms": 200,
        "text_suffixes": [
          ".content",
          ".summary",
          ".description",
          ".title",
          ".name",
          ".goal",
          ".context",
          ".issue",
          ".suggestion",
          ".source_code",
          ".signature",
          ".body"
        ]
      }
    },
    "graph-query": {
      "name": "graph-query",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "query_requests",
              "subject": "graph.query.>",
              "type": "nats-request"
            }
          ],
          "outputs": []
        },
        "request_timeout": "5s",
        "max_traversal_depth": 5,
        "max_traversal_nodes": 100
      }
    },
    "graph-gateway": {
      "name": "graph-gateway",
      "type": "gateway",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "http",
              "subject": ":8082",
              "type": "http"
            }
          ],
          "outputs": [
            {
              "name": "mutations",
              "subject": "graph.mutation.*",
              "type": "nats-request"
            }
          ]
        },
        "graphql_path": "/graphql",
        "mcp_path": "/mcp",
        "bind_address": ":8082",
        "enable_playground": true
      }
    },
    "planner": {
      "name": "planner",
      "type": "processor",
      "enabled": true,
      "config": {
        "timeout": "900s",
        "max_iterations": 5,
        "output_dir": "/workspace/.semspec/plans"
      }
    },
    "requirement-generator": {
      "name": "requirement-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "requirement-generator",
        "trigger_subject": "workflow.async.requirement-generator",
        "default_capability": "requirement_generation"
      }
    },
    "scenario-generator": {
      "name": "scenario-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "scenario-generator",
        "trigger_subject": "workflow.async.scenario-generator",
        "default_capability": "scenario_generation"
      }
    },
    "plan-manager": {
      "name": "plan-manager",
      "type": "processor",
      "enabled": true,
      "config": {
        "execution_bucket_name": "EXECUTION_STATES",
        "max_concurrent_planners": 3,
        "max_review_iterations": 3,
        "auto_approve": false,
        "default_capability": "planning"
      }
    },
    "plan-reviewer": {
      "name": "plan-reviewer",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "plan-reviewer",
        "trigger_subject": "workflow.async.plan-reviewer",
        "result_subject_prefix": "workflow.result.plan-reviewer",
        "default_capability": "reviewing",
        "auto_approve": false
      }
    },
    "project-manager": {
      "name": "project-manager",
      "type": "processor",
      "enabled": true,
      "config": {
        "repo_path": "/workspace"
      }
    },
    "scenario-orchestrator": {
      "name": "scenario-orchestrator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "scenario-orchestrator",
        "trigger_subject": "scenario.orchestrate.*",
        "workflow_trigger_subject": "workflow.trigger.requirement-execution-loop",
        "execution_timeout": "3600s"
      }
    },
    "requirement-executor": {
      "name": "requirement-executor",
      "type": "processor",
      "enabled": true,
      "config": {
        "timeout_seconds": 3600,
        "model": "gemini-flash",
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "structural-validator": {
      "name": "structural-validator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "structural-validator",
        "repo_path": "/workspace",
        "checklist_path": ".semspec/checklist.json",
        "default_timeout": "900s",
        "sandbox_url": "http://sandbox:8090"
      }
    },
    "execution-manager": {
      "name": "execution-manager",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_iterations": 5,
        "timeout_seconds": 3600,
        "model": "gemini-flash",
        "sandbox_url": "http://sandbox:8090",
        "graph_gateway_url": "http://localhost:8082",
        "indexing_budget": "30s",
        "benching_threshold": 3,
        "teams": {
          "enabled": true,
          "roster": [
            {
              "name": "alpha",
              "members": [
                {
                  "role": "tester",
                  "model": "gemini-flash"
                },
                {
                  "role": "builder",
                  "model": "gemini-flash"
                },
                {
                  "role": "reviewer",
                  "model": "gemini-flash"
                }
              ]
            },
            {
              "name": "bravo",
              "members": [
                {
                  "role": "tester",
                  "model": "gemini-flash"
                },
                {
                  "role": "builder",
                  "model": "gemini-flash"
                },
                {
                  "role": "reviewer",
                  "model": "gemini-flash"
                }
              ]
            }
          ]
        }
      }
    },
    "rule-processor-execution": {
      "name": "rule-processor",
      "type": "processor",
      "enabled": true,
      "config": {
        "rules_files": [
          "configs/rules/semspec-task-execution/handle-approved.json",
          "configs/rules/semspec-task-execution/handle-escalated.json",
          "configs/rules/semspec-task-execution/handle-error.json"
        ],
        "entity_watch_buckets": {
          "ENTITY_STATES": [
            "*.*.exec.task.run.*"
          ]
        },
        "entity": {
          "pattern": "*.*.exec.task.run.*",
          "watch_buckets": [
            "ENTITY_STATES"
          ]
        },
        "ports": {
          "inputs": [
            {
              "name": "entity_states",
              "subject": "ENTITY_STATES",
              "type": "kv-watch"
            }
          ],
          "outputs": [
            {
              "name": "triple_mutations",
              "subject": "graph.mutation.triple",
              "type": "nats"
            },
            {
              "name": "workflow_events",
              "subject": "workflow.events",
              "type": "nats"
            }
          ]
        }
      }
    },
    "rule-processor-coordination": {
      "name": "rule-processor",
      "type": "processor",
      "enabled": true,
      "config": {
        "rules_files": [
          "configs/rules/semspec-coordination/handle-completed.json"
        ],
        "entity_watch_buckets": {
          "ENTITY_STATES": [
            "*.*.exec.coord.run.*"
          ]
        },
        "entity": {
          "pattern": "*.*.exec.coord.run.*",
          "watch_buckets": [
            "ENTITY_STATES"
          ]
        },
        "ports": {
          "inputs": [
            {
              "name": "entity_states",
              "subject": "ENTITY_STATES",
              "type": "kv-watch"
            }
          ],
          "outputs": [
            {
              "name": "triple_mutations",
              "subject": "graph.mutation.triple",
              "type": "nats"
            },
            {
              "name": "workflow_events",
              "subject": "workflow.events",
              "type": "nats"
            }
          ]
        }
      }
    },
    "rule-processor-plan": {
      "name": "rule-processor",
      "type": "processor",
      "enabled": true,
      "config": {
        "rules_files": [
          "configs/rules/semspec-plan/handle-approved.json",
          "configs/rules/semspec-plan/handle-escalated.json",
          "configs/rules/semspec-plan/handle-error.json"
        ],
        "entity_watch_buckets": {
          "ENTITY_STATES": [
            "*.*.exec.plan.run.*"
          ]
        },
        "entity": {
          "pattern": "*.*.exec.plan.run.*",
          "watch_buckets": [
            "ENTITY_STATES"
          ]
        },
        "ports": {
          "inputs": [
            {
              "name": "entity_states",
              "subject": "ENTITY_STATES",
              "type": "kv-watch"
            }
          ],
          "outputs": [
            {
              "name": "triple_mutations",
              "subject": "graph.mutation.triple",
              "type": "nats"
            },
            {
              "name": "workflow_events",
              "subject": "workflow.events",
              "type": "nats"
            }
          ]
        }
      }
    },
    "rule-processor-scenario": {
      "name": "rule-processor",
      "type": "processor",
      "enabled": true,
      "config": {
        "rules_files": [
          "configs/rules/semspec-scenario-execution/handle-completed.json",
          "configs/rules/semspec-scenario-execution/handle-error.json",
          "configs/rules/semspec-scenario-execution/handle-failed.json"
        ],
        "entity_watch_buckets": {
          "ENTITY_STATES": [
            "*.*.exec.scenario.run.*"
          ]
        },
        "entity": {
          "pattern": "*.*.exec.scenario.run.*",
          "watch_buckets": [
            "ENTITY_STATES"
          ]
        },
        "ports": {
          "inputs": [
            {
              "name": "entity_states",
              "subject": "ENTITY_STATES",
              "type": "kv-watch"
            }
          ],
          "outputs": [
            {
              "name": "triple_mutations",
              "subject": "graph.mutation.triple",
              "type": "nats"
            },
            {
              "name": "workflow_events",
              "subject": "workflow.events",
              "type": "nats"
            }
          ]
        }
      }
    }
  },
  "streams": {
    "USER": {
      "subjects": [
        "user.message.>",
        "user.response.>",
        "user.signal.>"
      ],
      "max_age": "1h",
      "storage": "memory",
      "replicas": 1
    },
    "AGENT": {
      "subjects": [
        "agent.task.>",
        "dev.task.>",
        "agent.request.>",
        "agent.response.>",
        "agent.signal.>",
        "agent.complete.>",
        "agent.created.>",
        "agent.failed.>",
        "agent.context.compaction.>",
        "context.build.>",
        "context.built.>",
        "tool.execute.>",
        "tool.result.>",
        "question.ask.>",
        "question.answer.>",
        "question.timeout.>",
        "question.escalate.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    },
    "GRAPH": {
      "subjects": [
        "graph.ingest.entity",
        "graph.ingest.batch",
        "graph.ingest.manifest",
        "graph.ingest.status",
        "graph.ingest.predicates",
        "graph.export.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    },
    "SOURCES": {
      "subjects": [
        "source.ingest.>",
        "source.status.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    },
    "WORKFLOW": {
      "subjects": [
        "workflow.trigger.>",
        "workflow.async.>",
        "workflow.result.>",
        "workflow.callback.>",
        "workflow.step.complete.>",
        "workflow.step.result.>",
        "workflow.events.>",
        "workflow.validate.>",
        "workflow.task.complete",
        "output.workflow.>",
        "proposal.request.>",
        "design.request.>",
        "spec.request.>",
        "tasks.request.>",
        "approve.request.>",
        "archive.request.>",
        "github.request.>",
        "scenario.orchestrate.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    }
  }
}
