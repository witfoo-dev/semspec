{
  "version": "1.0.0",
  "platform": {
    "org": "mycompany",
    "id": "multipath-dev",
    "environment": "dev"
  },
  "nats": {
    "urls": [
      "nats://localhost:4222"
    ],
    "max_reconnects": -1,
    "reconnect_wait": "2s",
    "jetstream": {
      "enabled": true
    }
  },
  "components": {},
  "streams": {
    "AGENT": {
      "subjects": [
        "tool.execute.>",
        "tool.result.>",
        "graph.ingest.entity"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    }
  }
}
