{
  "version": "1.0.2",
  "platform": {
    "org": "semspec",
    "id": "semspec-e2e-mock",
    "environment": "test"
  },
  "nats": {
    "urls": [
      "nats://nats:4222"
    ],
    "max_reconnects": -1,
    "reconnect_wait": "2s",
    "jetstream": {
      "enabled": true
    }
  },
  "model_registry": {
    "capabilities": {
      "planning": {
        "description": "Plan generation (mock: returns canned plan)",
        "preferred": [
          "mock-planner"
        ],
        "fallback": [
          "mock-fast"
        ]
      },
      "writing": {
        "description": "Documentation, plans, specifications (mock)",
        "preferred": [
          "mock-planner"
        ],
        "fallback": [
          "mock-fast"
        ]
      },
      "coding": {
        "description": "Code generation (mock)",
        "preferred": [
          "mock-coder"
        ],
        "fallback": [
          "mock-fast"
        ]
      },
      "reviewing": {
        "description": "Plan review (mock: returns approved verdict)",
        "preferred": [
          "mock-reviewer"
        ],
        "fallback": [
          "mock-fast"
        ]
      },
      "requirement_generation": {
        "description": "Requirement decomposition (mock: returns canned requirements)",
        "preferred": [
          "mock-requirement-generator"
        ],
        "fallback": [
          "mock-planner"
        ]
      },
      "scenario_generation": {
        "description": "Scenario generation (mock: returns canned BDD scenarios)",
        "preferred": [
          "mock-scenario-generator"
        ],
        "fallback": [
          "mock-planner"
        ]
      },
      "fast": {
        "description": "Quick responses (mock)",
        "preferred": [
          "mock-fast"
        ],
        "fallback": []
      }
    },
    "endpoints": {
      "mock-planner": {
        "provider": "ollama",
        "url": "http://mock-llm:11434/v1",
        "model": "mock-planner",
        "max_tokens": 8192
      },
      "mock-reviewer": {
        "provider": "ollama",
        "url": "http://mock-llm:11434/v1",
        "model": "mock-reviewer",
        "max_tokens": 8192
      },
      "mock-requirement-generator": {
        "provider": "ollama",
        "url": "http://mock-llm:11434/v1",
        "model": "mock-requirement-generator",
        "max_tokens": 32768
      },
      "mock-scenario-generator": {
        "provider": "ollama",
        "url": "http://mock-llm:11434/v1",
        "model": "mock-scenario-generator",
        "max_tokens": 32768
      },
      "mock-coder": {
        "provider": "ollama",
        "url": "http://mock-llm:11434/v1",
        "model": "mock-coder",
        "max_tokens": 8192
      },
      "mock-fast": {
        "provider": "ollama",
        "url": "http://mock-llm:11434/v1",
        "model": "mock-fast",
        "max_tokens": 8192
      }
    },
    "defaults": {
      "model": "mock-planner"
    }
  },
  "services": {
    "service-manager": {
      "name": "service-manager",
      "enabled": true,
      "config": {
        "http_port": 8080
      }
    },
    "component-manager": {
      "name": "component-manager",
      "enabled": true,
      "config": {}
    },
    "heartbeat": {
      "name": "heartbeat",
      "enabled": false,
      "config": {}
    },
    "message-logger": {
      "name": "message-logger",
      "enabled": true,
      "config": {
        "buffer_size": 10000,
        "monitor_subjects": [
          "user.>",
          "agent.>",
          "tool.>",
          "graph.>",
          "workflow.>",
          "source.>",
          "context.>"
        ]
      }
    }
  },
  "components": {
    "agentic-dispatch": {
      "name": "agentic-dispatch",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_role": "general",
        "default_model": "mock-planner",
        "auto_continue": false,
        "stream_name": "USER",
        "permissions": {
          "view": [
            "*"
          ],
          "submit_task": [
            "*"
          ],
          "cancel_own": true,
          "cancel_any": [
            "admin"
          ],
          "approve": [
            "*"
          ]
        }
      }
    },
    "agentic-loop": {
      "name": "agentic-loop",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_iterations": 10,
        "timeout": "120s",
        "stream_name": "AGENT",
        "loops_bucket": "AGENT_LOOPS",
        "content_bucket": "AGENT_CONTENT"
      }
    },
    "agentic-model": {
      "name": "agentic-model",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "timeout": "120s",
        "endpoints": {
          "mock-planner": {
            "url": "http://mock-llm:11434/v1",
            "model": "mock-planner"
          },
          "mock-reviewer": {
            "url": "http://mock-llm:11434/v1",
            "model": "mock-reviewer"
          },
          "mock-requirement-generator": {
            "url": "http://mock-llm:11434/v1",
            "model": "mock-requirement-generator"
          },
          "mock-scenario-generator": {
            "url": "http://mock-llm:11434/v1",
            "model": "mock-scenario-generator"
          },
          "mock-coder": {
            "url": "http://mock-llm:11434/v1",
            "model": "mock-coder"
          },
          "mock-fast": {
            "url": "http://mock-llm:11434/v1",
            "model": "mock-fast"
          }
        },
        "model_aliases": {
          "mock-planner": "mock-planner",
          "mock-reviewer": "mock-reviewer",
          "mock-requirement-generator": "mock-requirement-generator",
          "mock-scenario-generator": "mock-scenario-generator",
          "mock-coder": "mock-coder",
          "mock-fast": "mock-fast",
          "default": "mock-planner"
        }
      }
    },
    "agentic-tools": {
      "name": "agentic-tools",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "consumer_name_suffix": "semspec-e2e"
      }
    },
    "rdf-export": {
      "name": "rdf-export",
      "type": "output",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entities_in",
              "subject": "graph.ingest.entity",
              "type": "jetstream",
              "stream_name": "GRAPH"
            }
          ],
          "outputs": [
            {
              "name": "rdf_out",
              "subject": "graph.export.rdf",
              "type": "nats"
            }
          ]
        },
        "format": "turtle",
        "profile": "minimal",
        "base_iri": "https://semspec.dev"
      }
    },
    "graph-ingest": {
      "name": "graph-ingest",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entities_in",
              "subject": "graph.ingest.entity",
              "type": "jetstream",
              "stream_name": "GRAPH"
            }
          ],
          "outputs": [
            {
              "name": "entity_states",
              "subject": "ENTITY_STATES",
              "type": "kv-write"
            }
          ]
        },
        "enable_hierarchy": true
      }
    },
    "graph-index": {
      "name": "graph-index",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "entity_watch",
              "subject": "ENTITY_STATES",
              "type": "kv-watch"
            }
          ],
          "outputs": [
            {
              "name": "outgoing_index",
              "subject": "OUTGOING_INDEX",
              "type": "kv"
            },
            {
              "name": "incoming_index",
              "subject": "INCOMING_INDEX",
              "type": "kv"
            },
            {
              "name": "alias_index",
              "subject": "ALIAS_INDEX",
              "type": "kv"
            },
            {
              "name": "predicate_index",
              "subject": "PREDICATE_INDEX",
              "type": "kv"
            }
          ]
        },
        "workers": 2,
        "batch_size": 50,
        "coalesce_ms": 100
      }
    },
    "graph-query": {
      "name": "graph-query",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "query_requests",
              "subject": "graph.query.>",
              "type": "nats-request"
            }
          ],
          "outputs": []
        },
        "request_timeout": "5s",
        "max_traversal_depth": 5,
        "max_traversal_nodes": 100
      }
    },
    "graph-gateway": {
      "name": "graph-gateway",
      "type": "gateway",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "http",
              "subject": ":8082",
              "type": "http"
            }
          ],
          "outputs": [
            {
              "name": "mutations",
              "subject": "graph.mutation.*",
              "type": "nats-request"
            }
          ]
        },
        "graphql_path": "/graphql",
        "mcp_path": "/mcp",
        "bind_address": ":8082",
        "enable_playground": true
      }
    },
    "workflow-processor": {
      "name": "workflow-processor",
      "type": "processor",
      "enabled": false,
      "config": {
        "stream_name": "WORKFLOW",
        "definitions_bucket": "WORKFLOW_DEFINITIONS",
        "executions_bucket": "WORKFLOW_EXECUTIONS",
        "default_timeout": "30m",
        "default_max_iterations": 10,
        "request_timeout": "5m",
        "workflow_files": [
          "configs/workflows/*.json"
        ]
      }
    },
    "reactive-workflow": {
      "name": "reactive-workflow",
      "type": "processor",
      "enabled": true,
      "config": {
        "state_bucket": "REACTIVE_STATE",
        "callback_stream_name": "WORKFLOW",
        "event_stream_name": "WORKFLOW",
        "default_timeout": "30m",
        "default_max_iterations": 10,
        "enable_metrics": true
      }
    },
    "planner": {
      "name": "planner",
      "type": "processor",
      "enabled": true,
      "config": {
        "timeout": "120s",
        "max_iterations": 5,
        "output_dir": "/workspace/.semspec/plans"
      }
    },
    "phase-generator": {
      "name": "phase-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "phase-generator",
        "trigger_subject": "workflow.async.phase-generator",
        "default_capability": "planning"
      }
    },
    "requirement-generator": {
      "name": "requirement-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "requirement-generator",
        "trigger_subject": "workflow.async.requirement-generator",
        "default_capability": "requirement_generation"
      }
    },
    "scenario-generator": {
      "name": "scenario-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "scenario-generator",
        "trigger_subject": "workflow.async.scenario-generator",
        "default_capability": "scenario_generation"
      }
    },
    "task-generator": {
      "name": "task-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "task-generator",
        "trigger_subject": "workflow.async.task-generator",
        "default_capability": "planning"
      }
    },
    "trajectory-api": {
      "name": "trajectory-api",
      "type": "processor",
      "enabled": true,
      "config": {
        "loops_bucket": "AGENT_LOOPS",
        "graph_gateway_url": "http://localhost:8082",
        "content_bucket": "AGENT_CONTENT",
        "org": "semspec",
        "platform": "semspec-e2e-mock"
      }
    },
    "plan-api": {
      "name": "plan-api",
      "type": "processor",
      "enabled": true,
      "config": {
        "execution_bucket_name": "WORKFLOW_EXECUTIONS",
        "max_concurrent_planners": 3,
        "max_review_iterations": 3,
        "auto_approve": true,
        "default_capability": "planning",
        "semsource_readiness_budget": "1s"
      }
    },
    "plan-reviewer": {
      "name": "plan-reviewer",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "plan-reviewer",
        "trigger_subject": "workflow.async.plan-reviewer",
        "result_subject_prefix": "workflow.result.plan-reviewer",
        "default_capability": "reviewing"
      }
    },
    "task-reviewer": {
      "name": "task-reviewer",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "task-reviewer",
        "trigger_subject": "workflow.async.task-reviewer",
        "result_subject_prefix": "workflow.result.task-reviewer",
        "default_capability": "reviewing"
      }
    },
    "project-api": {
      "name": "project-api",
      "type": "processor",
      "enabled": true,
      "config": {
        "repo_path": "/workspace"
      }
    },
    "structural-validator": {
      "name": "structural-validator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "structural-validator",
        "repo_path": "/workspace",
        "checklist_path": ".semspec/checklist.json",
        "default_timeout": "120s"
      }
    },
    "developer": {
      "name": "developer",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "consumer_name": "developer",
        "trigger_subject": "dev.task.development",
        "state_bucket": "REACTIVE_STATE",
        "default_capability": "coding",
        "timeout": "120s"
      }
    },
    "task-code-reviewer": {
      "name": "task-code-reviewer",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "task-code-reviewer",
        "trigger_subject": "workflow.async.task-code-reviewer",
        "state_bucket": "REACTIVE_STATE",
        "default_capability": "reviewing",
        "timeout": "5m",
        "repo_path": "/workspace"
      }
    }
  },
  "streams": {
    "USER": {
      "subjects": [
        "user.message.>",
        "user.response.>",
        "user.signal.>"
      ],
      "max_age": "1h",
      "storage": "memory",
      "replicas": 1
    },
    "AGENT": {
      "subjects": [
        "agent.task.>",
        "dev.task.>",
        "agent.request.>",
        "agent.response.>",
        "agent.signal.>",
        "agent.complete.>",
        "agent.created.>",
        "agent.failed.>",
        "agent.context.compaction.>",
        "context.build.>",
        "context.built.>",
        "tool.execute.>",
        "tool.result.>",
        "question.ask.>",
        "question.answer.>",
        "question.timeout.>",
        "question.escalate.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    },
    "GRAPH": {
      "subjects": [
        "graph.ingest.entity",
        "graph.ingest.batch",
        "graph.ingest.manifest",
        "graph.ingest.status",
        "graph.ingest.predicates",
        "graph.export.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    },
    "SOURCES": {
      "subjects": [
        "source.ingest.>",
        "source.status.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    },
    "WORKFLOW": {
      "subjects": [
        "workflow.trigger.>",
        "workflow.async.>",
        "workflow.result.>",
        "workflow.callback.>",
        "workflow.step.complete.>",
        "workflow.step.result.>",
        "workflow.events.>",
        "workflow.validate.>",
        "workflow.task.complete",
        "output.workflow.>",
        "proposal.request.>",
        "design.request.>",
        "spec.request.>",
        "tasks.request.>",
        "approve.request.>",
        "archive.request.>",
        "github.request.>"
      ],
      "max_age": "24h",
      "storage": "memory",
      "replicas": 1
    }
  }
}
