{
  "id": "task-execution-error",
  "type": "expression",
  "name": "Task Execution Error",
  "description": "When a task execution step fails or times out, mark as failed",
  "enabled": true,
  "entity": {
    "pattern": "semspec.local.exec.task.run.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.execution.phase",
      "operator": "eq",
      "value": "error"
    }
  ],
  "logic": "and",
  "on_enter": [
    {
      "type": "publish",
      "subject": "workflow.events.task.execution_failed",
      "properties": {
        "reason": "step_failed"
      }
    },
    {
      "type": "update_triple",
      "predicate": "workflow.execution.status",
      "object": "failed"
    }
  ]
}
