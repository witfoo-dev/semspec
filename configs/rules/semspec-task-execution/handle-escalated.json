{
  "id": "task-execution-escalated",
  "type": "expression",
  "name": "Task Execution Escalated",
  "description": "When iteration budget exceeded or non-fixable rejection, escalate",
  "enabled": true,
  "entity": {
    "pattern": "semspec.local.exec.task.run.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.execution.phase",
      "operator": "eq",
      "value": "escalated"
    }
  ],
  "logic": "and",
  "on_enter": [
    {
      "type": "publish",
      "subject": "workflow.events.task.escalated",
      "properties": {
        "reason": "iteration_budget_exceeded_or_nonfixable"
      }
    },
    {
      "type": "update_triple",
      "predicate": "workflow.execution.status",
      "object": "escalated"
    }
  ]
}
