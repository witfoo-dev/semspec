{
  "id": "scenario-execution-completed",
  "type": "expression",
  "name": "Scenario Execution Completed",
  "description": "When all nodes complete successfully, mark scenario as completed and publish event",
  "enabled": true,
  "entity": {
    "pattern": "local.semspec.workflow.scenario-execution.execution.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.execution.phase",
      "operator": "eq",
      "value": "completed"
    }
  ],
  "logic": "and",
  "on_enter": [
    {
      "type": "publish",
      "subject": "workflow.events.scenario.completed",
      "properties": {
        "reason": "all_nodes_completed"
      }
    },
    {
      "type": "update_triple",
      "predicate": "workflow.execution.status",
      "object": "completed"
    }
  ]
}
