{
  "id": "scenario-execution-failed",
  "type": "expression",
  "name": "Scenario Execution Failed",
  "description": "When a node fails, mark scenario as failed and publish event",
  "enabled": true,
  "entity": {
    "pattern": "semspec.local.exec.scenario.run.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.execution.phase",
      "operator": "eq",
      "value": "failed"
    }
  ],
  "logic": "and",
  "on_enter": [
    {
      "type": "publish",
      "subject": "workflow.events.scenario.failed",
      "properties": {
        "reason": "node_execution_failed"
      }
    },
    {
      "type": "update_triple",
      "predicate": "workflow.execution.status",
      "object": "failed"
    }
  ]
}
