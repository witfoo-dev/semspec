{
  "id": "review-error",
  "type": "expression",
  "name": "Review Error",
  "description": "When a review step fails, mark workflow as failed",
  "enabled": true,
  "entity": {
    "pattern": "local.semspec.workflow.*-review.execution.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.execution.phase",
      "operator": "eq",
      "value": "error"
    }
  ],
  "logic": "and",
  "on_enter": [
    {
      "type": "publish",
      "subject": "workflow.events.review.error",
      "properties": {
        "reason": "step_failed"
      }
    },
    {
      "type": "update_triple",
      "predicate": "workflow.execution.status",
      "object": "failed"
    }
  ]
}
