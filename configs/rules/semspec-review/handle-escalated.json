{
  "id": "review-escalated",
  "type": "expression",
  "name": "Review Escalated",
  "description": "When max iterations exceeded, escalate and notify",
  "enabled": true,
  "entity": {
    "pattern": "local.semspec.workflow.*-review.execution.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.execution.phase",
      "operator": "eq",
      "value": "escalated"
    }
  ],
  "logic": "and",
  "on_enter": [
    {
      "type": "publish",
      "subject": "workflow.events.review.escalated",
      "properties": {
        "reason": "max_iterations_exceeded"
      }
    },
    {
      "type": "update_triple",
      "predicate": "workflow.execution.status",
      "object": "escalated"
    }
  ]
}
