{
  "id": "coordination-error",
  "type": "expression",
  "name": "Coordination Error",
  "description": "When coordination encounters an error, mark workflow as failed and publish event",
  "enabled": true,
  "entity": {
    "pattern": "semspec.local.exec.coord.run.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.execution.phase",
      "operator": "eq",
      "value": "error"
    }
  ],
  "logic": "and",
  "on_enter": [
    {
      "type": "publish",
      "subject": "workflow.events.coordination.failed",
      "properties": {
        "reason": "coordination_error"
      }
    },
    {
      "type": "update_triple",
      "predicate": "workflow.execution.status",
      "object": "failed"
    }
  ]
}
