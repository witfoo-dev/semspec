{
  "id": "coordination-completed",
  "type": "expression",
  "name": "Coordination Completed",
  "description": "When coordination completes, mark workflow status as completed and publish event",
  "enabled": true,
  "entity": {
    "pattern": "local.semspec.workflow.coordination.execution.*",
    "watch_buckets": ["ENTITY_STATES"]
  },
  "conditions": [
    {
      "field": "workflow.execution.phase",
      "operator": "eq",
      "value": "completed"
    }
  ],
  "logic": "and",
  "on_enter": [
    {
      "type": "publish",
      "subject": "workflow.events.coordination.completed",
      "properties": {
        "reason": "coordination_completed"
      }
    },
    {
      "type": "update_triple",
      "predicate": "workflow.execution.status",
      "object": "completed"
    }
  ]
}
