{
  "version": "1.0.0",
  "platform": {
    "org": "semspec",
    "id": "semspec-dev",
    "environment": "dev"
  },
  "model_registry": {
    "capabilities": {
      "planning": {
        "description": "High-level reasoning, architecture decisions",
        "preferred": ["claude-opus", "claude-sonnet"],
        "fallback": ["qwen3", "qwen"]
      },
      "writing": {
        "description": "Documentation, proposals, specifications",
        "preferred": ["claude-sonnet"],
        "fallback": ["qwen3", "qwen"]
      },
      "coding": {
        "description": "Code generation, implementation",
        "preferred": ["claude-sonnet"],
        "fallback": ["qwen", "qwen3"]
      },
      "reviewing": {
        "description": "Code review, quality analysis",
        "preferred": ["claude-sonnet"],
        "fallback": ["qwen3", "qwen"]
      },
      "fast": {
        "description": "Quick responses, simple tasks",
        "preferred": ["claude-haiku"],
        "fallback": ["qwen3-fast", "qwen"]
      }
    },
    "endpoints": {
      "claude-opus": {
        "provider": "anthropic",
        "model": "claude-opus-4-5-20251101",
        "max_tokens": 200000,
        "supports_tools": true,
        "tool_format": "anthropic"
      },
      "claude-sonnet": {
        "provider": "anthropic",
        "model": "claude-sonnet-4-20250514",
        "max_tokens": 200000,
        "supports_tools": true,
        "tool_format": "anthropic"
      },
      "claude-haiku": {
        "provider": "anthropic",
        "model": "claude-haiku-3-5-20241022",
        "max_tokens": 200000,
        "supports_tools": true,
        "tool_format": "anthropic"
      },
      "qwen": {
        "provider": "ollama",
        "url": "${LLM_API_URL:-http://localhost:11434}/v1",
        "model": "qwen3-coder:30b",
        "max_tokens": 131072,
        "supports_tools": true,
        "tool_format": "openai"
      },
      "qwen3": {
        "provider": "ollama",
        "url": "${LLM_API_URL:-http://localhost:11434}/v1",
        "model": "qwen3:14b",
        "max_tokens": 32768
      },
      "qwen3-fast": {
        "provider": "ollama",
        "url": "${LLM_API_URL:-http://localhost:11434}/v1",
        "model": "qwen3:1.7b",
        "max_tokens": 32768
      },
      "llama3.2": {
        "provider": "ollama",
        "url": "${LLM_API_URL:-http://localhost:11434}/v1",
        "model": "llama3.2",
        "max_tokens": 128000
      },
      "codellama": {
        "provider": "ollama",
        "url": "${LLM_API_URL:-http://localhost:11434}/v1",
        "model": "codellama",
        "max_tokens": 16384
      }
    },
    "defaults": {
      "model": "qwen"
    }
  },
  "nats": {
    "urls": ["${NATS_URL:-nats://localhost:4222}"],
    "max_reconnects": -1,
    "reconnect_wait": "2s",
    "jetstream": {
      "enabled": true
    }
  },
  "services": {
    "service-manager": {
      "name": "service-manager",
      "enabled": true,
      "config": {
        "http_port": 8080
      }
    },
    "component-manager": {
      "name": "component-manager",
      "enabled": true,
      "config": {}
    },
    "heartbeat": {
      "name": "heartbeat",
      "enabled": false,
      "config": {}
    },
    "message-logger": {
      "name": "message-logger",
      "enabled": true,
      "config": {
        "buffer_size": 10000,
        "monitor_subjects": ["user.>", "agent.>", "tool.>", "graph.>", "context.>", "workflow.>"]
      }
    }
  },
  "components": {
    "ast-indexer": {
      "name": "ast-indexer",
      "type": "processor",
      "enabled": true,
      "config": {
        "watch_paths": [
          {
            "path": "${SEMSPEC_REPO_PATH:-.}",
            "org": "semspec",
            "project": "semspec",
            "languages": ["go", "typescript", "python", "java", "javascript"],
            "excludes": ["vendor", "node_modules", "dist", ".next", "build", "coverage"]
          }
        ],
        "watch_enabled": true,
        "index_interval": "60s"
      }
    },
    "agentic-dispatch": {
      "name": "agentic-dispatch",
      "type": "processor",
      "enabled": true,
      "config": {
        "default_role": "general",
        "default_model": "qwen",
        "auto_continue": false,
        "stream_name": "USER",
        "permissions": {
          "view": ["*"],
          "submit_task": ["*"],
          "cancel_own": true,
          "cancel_any": ["admin"],
          "approve": ["*"]
        }
      }
    },
    "agentic-loop": {
      "name": "agentic-loop",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_iterations": 15,
        "timeout": "300s",
        "stream_name": "AGENT",
        "loops_bucket": "AGENT_LOOPS",
        "trajectories_bucket": "AGENT_TRAJECTORIES",
        "context": {
          "summarization_model": "fast"
        }
      }
    },
    "agentic-model": {
      "name": "agentic-model",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "timeout": "120s"
      }
    },
    "agentic-tools": {
      "name": "agentic-tools",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "consumer_name_suffix": "semspec"
      }
    },
    "question-answerer": {
      "name": "question-answerer",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "consumer_name": "question-answerer",
        "task_subject": "dev.task.question-answerer",
        "default_capability": "planning"
      }
    },
    "question-timeout": {
      "name": "question-timeout",
      "type": "processor",
      "enabled": false,
      "config": {
        "check_interval": "1m",
        "default_sla": "24h"
      }
    },
    "requirement-generator": {
      "name": "requirement-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "requirement-generator",
        "trigger_subject": "workflow.async.requirement-generator",
        "default_capability": "planning",
        "context_subject_prefix": "context.build",
        "context_timeout": "60s"
      }
    },
    "phase-generator": {
      "name": "phase-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "phase-generator",
        "trigger_subject": "workflow.async.phase-generator",
        "default_capability": "planning",
        "context_subject_prefix": "context.build",
        "context_timeout": "60s"
      }
    },
    "scenario-generator": {
      "name": "scenario-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "scenario-generator",
        "trigger_subject": "workflow.async.scenario-generator",
        "default_capability": "planning",
        "context_subject_prefix": "context.build",
        "context_timeout": "60s"
      }
    },
    "task-generator": {
      "name": "task-generator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "task-generator",
        "trigger_subject": "workflow.async.task-generator",
        "default_capability": "planning",
        "context_subject_prefix": "context.build",
        "context_timeout": "60s",
        "reactive_mode": true
      }
    },
    "task-dispatcher": {
      "name": "task-dispatcher",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "task-dispatcher",
        "trigger_subject": "workflow.trigger.task-dispatcher",
        "output_subject": "workflow.result.task-dispatcher",
        "max_concurrent": 3,
        "context_timeout": "30s",
        "execution_timeout": "300s",
        "context_subject_prefix": "context.build",
        "agent_task_subject": "dev.task.development"
      }
    },
    "planner": {
      "name": "planner",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "planner",
        "trigger_subject": "workflow.async.planner",
        "default_capability": "planning"
      }
    },
    "plan-coordinator": {
      "name": "plan-coordinator",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_concurrent_planners": 3,
        "timeout_seconds": 1800,
        "model": "default",
        "default_capability": "planning",
        "context_subject_prefix": "context.build",
        "context_timeout": "30s"
      }
    },
    "plan-reviewer": {
      "name": "plan-reviewer",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "plan-reviewer",
        "trigger_subject": "workflow.async.plan-reviewer",
        "result_subject_prefix": "workflow.result.plan-reviewer",
        "llm_timeout": "120s",
        "default_capability": "reviewing",
        "context_subject_prefix": "context.build",
        "context_timeout": "60s"
      }
    },
    "task-reviewer": {
      "name": "task-reviewer",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "task-reviewer",
        "trigger_subject": "workflow.async.task-reviewer",
        "result_subject_prefix": "workflow.result.task-reviewer",
        "llm_timeout": "120s",
        "default_capability": "reviewing",
        "context_subject_prefix": "context.build",
        "context_timeout": "60s"
      }
    },
    "context-builder": {
      "name": "context-builder",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "AGENT",
        "consumer_name": "context-builder",
        "input_subject_pattern": "context.build.>",
        "output_subject_prefix": "context.built",
        "default_token_budget": 32000,
        "graph_gateway_url": "http://localhost:8082",
        "default_capability": "reviewing",
        "sop_entity_prefix": "c360.semspec.source.doc",
        "response_bucket_name": "CONTEXT_RESPONSES",
        "response_ttl_hours": 24
      }
    },
    "project-api": {
      "name": "project-api",
      "type": "processor",
      "enabled": true,
      "config": {
        "repo_path": "${SEMSPEC_REPO_PATH:-}"
      }
    },
    "workflow-api": {
      "name": "workflow-api",
      "type": "processor",
      "enabled": true,
      "config": {
        "execution_bucket_name": "WORKFLOW_EXECUTIONS"
      }
    },
    "trajectory-api": {
      "name": "trajectory-api",
      "type": "processor",
      "enabled": true,
      "config": {
        "llm_calls_bucket": "LLM_CALLS",
        "loops_bucket": "AGENT_LOOPS",
        "graph_gateway_url": "http://localhost:8082"
      }
    },
    "workflow-validator": {
      "name": "workflow-validator",
      "type": "processor",
      "enabled": true,
      "config": {
        "timeout_secs": 30
      }
    },
    "structural-validator": {
      "name": "structural-validator",
      "type": "processor",
      "enabled": false,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "structural-validator",
        "checklist_path": ".semspec/checklist.json",
        "default_timeout": "120s"
      }
    },
    "workflow-documents": {
      "name": "workflow-documents",
      "type": "output",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [
            {
              "name": "documents_in",
              "type": "jetstream",
              "subject": "output.workflow.documents",
              "stream_name": "WORKFLOW",
              "required": true,
              "description": "Workflow document output messages"
            }
          ],
          "outputs": [
            {
              "name": "documents_written",
              "type": "nats",
              "subject": "workflow.documents.written",
              "required": false,
              "description": "Notification when documents are written"
            }
          ]
        }
      }
    },
    "review-orchestrator": {
      "name": "review-orchestrator",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_iterations": 3,
        "timeout_seconds": 1800,
        "model": "default",
        "ports": {
          "inputs": [
            {"name": "plan-review-trigger", "subject": "workflow.trigger.plan-review-loop", "type": "jetstream", "stream_name": "WORKFLOW", "description": "Receive plan review loop triggers", "required": true},
            {"name": "phase-review-trigger", "subject": "workflow.trigger.phase-review-loop", "type": "jetstream", "stream_name": "WORKFLOW", "description": "Receive phase review loop triggers", "required": true},
            {"name": "task-review-trigger", "subject": "workflow.trigger.task-review-loop", "type": "jetstream", "stream_name": "WORKFLOW", "description": "Receive task review loop triggers", "required": true},
            {"name": "loop-completions", "subject": "agentic.loop_completed.v1", "type": "jetstream", "stream_name": "AGENT", "description": "Receive agentic loop completion events", "required": true}
          ],
          "outputs": [
            {"name": "entity-triples", "subject": "graph.mutation.triple.add", "type": "nats", "description": "Publish entity state triples", "required": false},
            {"name": "agent-tasks", "subject": "agent.task.>", "type": "nats", "description": "Dispatch agent tasks for generation and review", "required": false}
          ]
        }
      }
    },
    "rule-processor-review": {
      "name": "rule-processor",
      "type": "processor",
      "enabled": true,
      "config": {
        "rules_dir": "configs/rules/semspec-review",
        "entity": {
          "pattern": "local.semspec.workflow.*-review.execution.*",
          "watch_buckets": ["ENTITY_STATES"]
        },
        "ports": {
          "inputs": [
            {"name": "entity_states", "subject": "ENTITY_STATES.>", "type": "kv-watch", "bucket": "ENTITY_STATES"}
          ],
          "outputs": [
            {"name": "triple_mutations", "subject": "graph.mutation.triple", "type": "nats"},
            {"name": "workflow_events", "subject": "workflow.events", "type": "nats"}
          ]
        }
      }
    },
    "execution-orchestrator": {
      "name": "execution-orchestrator",
      "type": "processor",
      "enabled": true,
      "config": {
        "max_iterations": 3,
        "timeout_seconds": 1800,
        "model": "default",
        "ports": {
          "inputs": [
            {"name": "execution-trigger", "subject": "workflow.trigger.task-execution-loop", "type": "jetstream", "stream_name": "WORKFLOW", "description": "Receive task execution triggers from task-dispatcher", "required": true},
            {"name": "loop-completions", "subject": "agentic.loop_completed.v1", "type": "jetstream", "stream_name": "AGENT", "description": "Receive agentic loop completion events", "required": true}
          ],
          "outputs": [
            {"name": "entity-triples", "subject": "graph.mutation.triple.add", "type": "nats", "description": "Publish entity state triples", "required": false},
            {"name": "agent-tasks", "subject": "agent.task.>", "type": "nats", "description": "Dispatch agent tasks", "required": false}
          ]
        }
      }
    },
    "rule-processor-execution": {
      "name": "rule-processor",
      "type": "processor",
      "enabled": true,
      "config": {
        "rules_dir": "configs/rules/semspec-task-execution",
        "entity": {
          "pattern": "local.semspec.workflow.task-execution.execution.*",
          "watch_buckets": ["ENTITY_STATES"]
        },
        "ports": {
          "inputs": [
            {"name": "entity_states", "subject": "ENTITY_STATES.>", "type": "kv-watch", "bucket": "ENTITY_STATES"}
          ],
          "outputs": [
            {"name": "triple_mutations", "subject": "graph.mutation.triple", "type": "nats"},
            {"name": "workflow_events", "subject": "workflow.events", "type": "nats"}
          ]
        }
      }
    },
    "rule-processor-coordination": {
      "name": "rule-processor",
      "type": "processor",
      "enabled": true,
      "config": {
        "rules_dir": "configs/rules/semspec-coordination",
        "entity": {
          "pattern": "local.semspec.workflow.coordination.execution.*",
          "watch_buckets": ["ENTITY_STATES"]
        },
        "ports": {
          "inputs": [
            {"name": "entity_states", "subject": "ENTITY_STATES.>", "type": "kv-watch", "bucket": "ENTITY_STATES"}
          ],
          "outputs": [
            {"name": "triple_mutations", "subject": "graph.mutation.triple", "type": "nats"},
            {"name": "workflow_events", "subject": "workflow.events", "type": "nats"}
          ]
        }
      }
    },
    "scenario-orchestrator": {
      "name": "scenario-orchestrator",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "scenario-orchestrator",
        "trigger_subject": "scenario.orchestrate.*",
        "workflow_trigger_subject": "workflow.trigger.scenario-execution-loop",
        "execution_timeout": "120s",
        "max_concurrent": 5,
        "ports": {
          "inputs": [
            {"name": "orchestration-triggers", "subject": "scenario.orchestrate.*", "type": "jetstream", "stream_name": "WORKFLOW", "description": "Receive scenario orchestration triggers", "required": true}
          ],
          "outputs": [
            {"name": "scenario-execution-triggers", "subject": "workflow.trigger.scenario-execution-loop", "type": "nats", "description": "Trigger scenario-executor for each pending scenario"}
          ]
        }
      }
    },
    "scenario-executor": {
      "name": "scenario-executor",
      "type": "processor",
      "enabled": true,
      "config": {
        "timeout_seconds": 3600,
        "model": "default",
        "ports": {
          "inputs": [
            {"name": "scenario-trigger", "subject": "workflow.trigger.scenario-execution-loop", "type": "jetstream", "stream_name": "WORKFLOW", "description": "Receive scenario execution triggers from scenario-orchestrator", "required": true},
            {"name": "loop-completions", "subject": "agentic.loop_completed.v1", "type": "jetstream", "stream_name": "AGENT", "description": "Receive agentic loop completion events", "required": true}
          ],
          "outputs": [
            {"name": "entity-triples", "subject": "graph.mutation.triple.add", "type": "nats", "description": "Publish entity state triples"},
            {"name": "agent-tasks", "subject": "agent.task.>", "type": "nats", "description": "Dispatch agent tasks for decomposition and node execution"}
          ]
        }
      }
    },
    "change-proposal-handler": {
      "name": "change-proposal-handler",
      "type": "processor",
      "enabled": true,
      "config": {
        "stream_name": "WORKFLOW",
        "consumer_name": "change-proposal-handler",
        "trigger_subject": "workflow.trigger.change-proposal-cascade",
        "accepted_subject": "workflow.events.change-proposal.accepted",
        "timeout_seconds": 120,
        "ports": {
          "inputs": [
            {"name": "cascade-triggers", "subject": "workflow.trigger.change-proposal-cascade", "type": "jetstream", "stream_name": "WORKFLOW", "description": "Receive cascade requests when a ChangeProposal is accepted", "required": true}
          ],
          "outputs": [
            {"name": "accepted-events", "subject": "workflow.events.change-proposal.accepted", "type": "jetstream", "stream_name": "WORKFLOW", "description": "Publish accepted event with cascade summary"},
            {"name": "cancellation-signals", "subject": "agent.signal.cancel.*", "type": "nats", "description": "Cancel running scenario loops affected by cascade"}
          ]
        }
      }
    },
    "rule-processor-scenario": {
      "name": "rule-processor",
      "type": "processor",
      "enabled": true,
      "config": {
        "rules_dir": "configs/rules/semspec-scenario-execution",
        "entity": {
          "pattern": "local.semspec.workflow.scenario-execution.execution.*",
          "watch_buckets": ["ENTITY_STATES"]
        },
        "ports": {
          "inputs": [
            {"name": "entity_states", "subject": "ENTITY_STATES.>", "type": "kv-watch", "bucket": "ENTITY_STATES"}
          ],
          "outputs": [
            {"name": "triple_mutations", "subject": "graph.mutation.triple", "type": "nats"},
            {"name": "workflow_events", "subject": "workflow.events", "type": "nats"}
          ]
        }
      }
    },
    "source-ingester": {
      "name": "source-ingester",
      "type": "processor",
      "enabled": false,
      "config": {
        "stream_name": "SOURCES",
        "consumer_name": "source-ingester",
        "sources_dir": ".semspec/sources/docs",
        "analysis_timeout": "30s",
        "chunk_config": {
          "target_tokens": 1000,
          "max_tokens": 1500,
          "min_tokens": 200
        }
      }
    },
    "rdf-export": {
      "name": "rdf-export",
      "type": "output",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [{
            "name": "entities_in",
            "subject": "graph.ingest.entity",
            "type": "jetstream",
            "stream_name": "GRAPH"
          }],
          "outputs": [{
            "name": "rdf_out",
            "subject": "graph.export.rdf",
            "type": "nats"
          }]
        },
        "format": "turtle",
        "profile": "minimal",
        "base_iri": "https://semspec.dev"
      }
    },
    "graph-ingest": {
      "name": "graph-ingest",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [{
            "name": "entities_in",
            "subject": "graph.ingest.entity",
            "type": "jetstream",
            "stream_name": "GRAPH"
          }],
          "outputs": [{
            "name": "entity_states",
            "subject": "ENTITY_STATES",
            "type": "kv-write"
          }]
        },
        "enable_hierarchy": true
      }
    },
    "graph-index": {
      "name": "graph-index",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [{
            "name": "entity_watch",
            "subject": "ENTITY_STATES",
            "type": "kv-watch"
          }],
          "outputs": [
            {"name": "outgoing_index", "subject": "OUTGOING_INDEX", "type": "kv"},
            {"name": "incoming_index", "subject": "INCOMING_INDEX", "type": "kv"},
            {"name": "alias_index", "subject": "ALIAS_INDEX", "type": "kv"},
            {"name": "predicate_index", "subject": "PREDICATE_INDEX", "type": "kv"}
          ]
        },
        "workers": 2,
        "batch_size": 50
      }
    },
    "graph-query": {
      "name": "graph-query",
      "type": "processor",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [{
            "name": "query_requests",
            "subject": "graph.query.>",
            "type": "nats-request"
          }],
          "outputs": []
        },
        "request_timeout": "5s",
        "max_traversal_depth": 5,
        "max_traversal_nodes": 100
      }
    },
    "graph-gateway": {
      "name": "graph-gateway",
      "type": "gateway",
      "enabled": true,
      "config": {
        "ports": {
          "inputs": [{"name": "http", "subject": ":8082", "type": "http"}],
