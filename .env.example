# WitFoo Semspec Configuration
# Copy to .env and fill in required values.

# ---------- Port Remapping (avoid conflicts with analytics stack) ----------
SEMSPEC_GATEWAY_PORT=8880
SEMSPEC_NATS_PORT=4922
SEMSPEC_NATS_MONITOR_PORT=8922
SEMSPEC_SANDBOX_PORT=8890
LISTEN_IP=0.0.0.0

# ---------- LLM Provider ----------
# Anthropic Claude API (default — consistent with Claude Code usage)
ANTHROPIC_API_KEY=

# Ollama (alternative for disconnected networks)
# Uncomment and set OLLAMA_HOST to use Ollama instead of Anthropic:
# OLLAMA_HOST=http://host.docker.internal:11434

# ---------- Repository Path ----------
# Path to the analytics repo root (relative to utils/semspec/)
SEMSPEC_REPO=../../
